{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python hooks/deliverable_bom_sync.py"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python hooks/deliverable_bom_sync.py"
          }
        ]
      },
      {
        "matcher": "mcp__freecad__execute_code",
        "hooks": [
          {
            "type": "command",
            "command": "python hooks/cad_post_execute.py"
          },
          {
            "type": "command",
            "command": "python hooks/assembly_validate.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "mcp__freecad__*",
        "hooks": [
          {
            "type": "command",
            "command": "python hooks/freecad_autolaunch.py"
          }
        ]
      },
      {
        "matcher": "mcp__freecad__execute_code",
        "hooks": [
          {
            "type": "command",
            "command": "python hooks/cad_pre_execute.py"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "python hooks/workflow_step_guard.py"
          },
          {
            "type": "command",
            "command": "python hooks/aero_consensus_check.py"
          },
          {
            "type": "command",
            "command": "python hooks/complexity_check.py"
          },
          {
            "type": "command",
            "command": "python hooks/anti_simplification_hook.py"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python hooks/workflow_step_guard.py"
          },
          {
            "type": "command",
            "command": "python hooks/anti_simplification_hook.py"
          }
        ]
      }
    ]
  }
}
